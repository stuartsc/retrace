<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>Retrace</string>
    <key>CFBundleDisplayName</key>
    <string>Retrace</string>
    <key>CFBundleIdentifier</key>
    <string>io.retrace.app</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>Retrace</string>

    <!-- App Icon -->
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>

    <!-- URL Scheme for deeplinks -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>Retrace Deeplink</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>retrace</string>
            </array>
        </dict>
    </array>

    <!-- Minimum macOS version -->
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>

    <!-- Application Category -->
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.productivity</string>

    <!-- High Resolution Support -->
    <key>NSHighResolutionCapable</key>
    <true/>

    <!-- Privacy - Screen Recording Usage Description -->
    <key>NSScreenCaptureUsageDescription</key>
    <string>Retrace needs screen recording permission to capture your screen history. All data stays local and encrypted on your Mac.</string>

    <!-- Privacy - Accessibility Usage Description -->
    <key>NSAppleEventsUsageDescription</key>
    <string>Retrace needs Automation permission to extract the browser url. If you're getting this notice, you're likely using an application that doesn't support url extraction via accessibility APIs, so URL Extraction needs to be done via Apple Script. All data stays local and encrypted on your Mac.</string>

    <!-- Required Entitlements -->
    <key>com.apple.security.device.screen-recording</key>
    <true/>
    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <!-- LSUIElement: Run as menu bar app (no dock icon) -->
    <!-- Set to false if you want the app in the Dock -->
    <key>LSUIElement</key>
    <true/>

    <!-- Support for Dark Mode -->
    <key>NSRequiresAquaSystemAppearance</key>
    <false/>

    <!-- Prevent multiple instances -->
    <key>LSMultipleInstancesProhibited</key>
    <true/>

    <!-- Sparkle Auto-Update: Disabled (forked project, no appcast feed configured) -->
    <!-- To re-enable: add SUFeedURL, SUPublicEDKey, and SUEnableAutomaticChecks keys -->
</dict>
</plist>
